{
  "$schema": "https://opencode.ai/schemas/mcp-config-v1.json",
  "mcp": {
    "servers": {
      "mfs-memory": {
        "command": "python3",
        "args": [
          "-m",
          "mfs.mcp_server"
        ],
        "cwd": "/root/.openclaw/workspace/projects/mfs-memory",
        "env": {
          "MFS_DB_PATH": "/root/.openclaw/workspace/projects/mfs-memory/mfs.db",
          "PYTHONPATH": "/root/.openclaw/workspace/projects/mfs-memory"
        },
        "disabled": false,
        "timeout": 60
      },
      "hermes": {
        "command": "onairos-hermes-mcp",
        "args": [],
        "env": {},
        "disabled": false
      },
      "filesystem": {
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "/root/.openclaw/workspace"
        ],
        "env": {},
        "disabled": false
      }
    }
  }
}
